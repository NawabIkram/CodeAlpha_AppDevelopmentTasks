<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CodeAlphaFitnessTracker" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/screen_top</item>
        <item name="android:navigationBarColor">@color/card_background</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.CodeAlphaFitnessTracker.AlertDialog</item>
    </style>

    <style name="ThemeOverlay.CodeAlphaFitnessTracker.AlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.CodeAlphaFitnessTracker.Dialog</item>
    </style>

    <style name="ShapeAppearance.CodeAlphaFitnessTracker.Dialog" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">22dp</item>
    </style>
</resources>
