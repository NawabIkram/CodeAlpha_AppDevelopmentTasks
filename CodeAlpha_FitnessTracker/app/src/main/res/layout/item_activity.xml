<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/card_stroke"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="108dp"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvActivityInitial"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_activity_initial"
            android:gravity="center"
            android:text="R"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvActivityType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toEndOf="@id/tvActivityInitial"
            app:layout_constraintTop_toTopOf="@id/tvActivityInitial"
            tools:text="Running" />

        <TextView
            android:id="@+id/tvActivityDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@id/actionContainer"
            app:layout_constraintStart_toEndOf="@id/tvActivityInitial"
            app:layout_constraintTop_toBottomOf="@id/tvActivityType"
            tools:text="25 Jun 2026" />

        <LinearLayout
            android:id="@+id/actionContainer"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnEdit"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:background="@drawable/bg_action_button"
                android:contentDescription="@string/edit_activity"
                android:padding="10dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/primary" />

            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_delete_button"
                android:contentDescription="@string/delete_activity"
                android:padding="10dp"
                android:src="@drawable/ic_delete"
                app:tint="@color/danger" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/metricsContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvActivityInitial"
            app:layout_constraintTop_toBottomOf="@id/tvActivityDate">

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_metric_chip"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_time"
                app:drawableTint="@color/secondary"
                tools:text="30 min" />

            <TextView
                android:id="@+id/tvCalories"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_calorie_chip"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/accent_orange"
                android:textSize="12sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_fire"
                app:drawableTint="@color/accent_orange"
                tools:text="240 kcal" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNotes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_notes"
            android:padding="9dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/metricsContainer"
            tools:text="Comfortable morning session." />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
