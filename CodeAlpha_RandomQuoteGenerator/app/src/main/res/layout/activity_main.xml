<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_gradient"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:text="@string/app_title"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/app_subtitle"
            android:textColor="@color/white_80"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/quoteCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_quote_card"
            android:elevation="12dp"
            android:gravity="center_horizontal"
            android:minHeight="300dp"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="22dp"
            android:paddingEnd="26dp"
            android:paddingBottom="26dp">

            <TextView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_quote_icon"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:text="@string/quote_icon"
                android:textColor="@color/primary"
                android:textSize="42sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/quoteContentGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvQuote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="center"
                    android:lineSpacingExtra="5dp"
                    android:textColor="@color/text_primary"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="52dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_accent_line" />

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnNewQuote"
            style="@style/Widget.CodeAlpha.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="22dp"
            android:text="@string/new_quote_button" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCopy"
                style="@style/Widget.CodeAlpha.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/copy_button" />

            <Button
                android:id="@+id/btnShare"
                style="@style/Widget.CodeAlpha.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/share_button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnFavorite"
                style="@style/Widget.CodeAlpha.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="@string/favorite_button" />

            <Button
                android:id="@+id/btnViewFavorites"
                style="@style/Widget.CodeAlpha.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/view_favorites_button" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:text="@string/footer_text"
            android:textColor="@color/white_70"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>
